# scan2report — Environment Variable Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# .env is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── AI Features (optional) ───────────────────────────────────────────────────
# Enables the "Analyze with AI" feature (option 5 in CLI, button in web UI).
# Get your free API token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here


# ── Flask Web App ─────────────────────────────────────────────────────────────
# Secret key used to sign session cookies.
# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-random-secret-string


# ── Server Config (optional) ─────────────────────────────────────────────────
# Port the Flask web app listens on (default: 5000)
PORT=5000
